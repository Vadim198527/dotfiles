# BEGIN_KITTY_THEME
# Catppuccin-Mocha
# include current-theme.conf

# END_KITTY_THEME
font_family      Iosevka Nerd Font
bold_font        auto
italic_font      auto
bold_italic_font auto

background_opacity 0.7

font_size 15.0

map ctrl+c copy_to_clipboard
map ctrl+v paste_from_clipboard

# Привязка Ctrl+C для отправки сигнала SIGINT (Ctrl+C)
# map ctrl+c send_text all "\x03"

# Привязка Ctrl+D для отправки EOF (Ctrl+D)
# map ctrl+d send_text all "\x04"

